OPENAI_API_KEY=
OPENAI_API_BASE_URL=

# Directory containing package folders.
# For a mounted full dataset:
# EVIDENT_DATA_ROOT=/path/to/EvidenT-riscv-219-dataset/packages
EVIDENT_DATA_ROOT=dataset/obs_data/risc_v

# Optional comma-separated package names and package count limit for quick runs.
EVIDENT_PACKAGES=
EVIDENT_PACKAGE_LIMIT=1
